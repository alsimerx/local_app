generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("requester")
  department   String?
  position     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests              Request[]
  approvalSteps         ApprovalStep[]
  auditLogs             AuditLog[]
  templateStepApprovers TemplateStepApprover[]
  notifications         Notification[]
}

model WorkflowTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fields   TemplateField[]
  steps    TemplateStep[]
  requests Request[]
}

model TemplateField {
  id         Int     @id @default(autoincrement())
  templateId Int
  label      String
  fieldType  String
  required   Boolean @default(false)
  options    String?
  order      Int

  template WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model TemplateStep {
  id         Int    @id @default(autoincrement())
  templateId Int
  order      Int
  name       String

  template      WorkflowTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  approvers     TemplateStepApprover[]
  approvalSteps ApprovalStep[]
}

model TemplateStepApprover {
  id     Int @id @default(autoincrement())
  stepId Int
  userId Int

  step TemplateStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])
}

model Request {
  id            Int       @id @default(autoincrement())
  requestNumber String    @unique
  templateId    Int
  requesterId   Int
  title         String
  formData      String
  status        String    @default("draft")
  currentStep   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  submittedAt   DateTime?
  completedAt   DateTime?

  template      WorkflowTemplate    @relation(fields: [templateId], references: [id])
  requester     User                @relation(fields: [requesterId], references: [id])
  approvalSteps ApprovalStep[]
  attachments   RequestAttachment[]
  auditLogs     AuditLog[]
  notifications Notification[]
}

model RequestAttachment {
  id         Int      @id @default(autoincrement())
  requestId  Int
  filename   String
  filePath   String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model ApprovalStep {
  id             Int       @id @default(autoincrement())
  requestId      Int
  templateStepId Int?
  stepOrder      Int
  approverId     Int
  status         String    @default("pending")
  comment        String?
  actionedAt     DateTime?
  createdAt      DateTime  @default(now())

  request      Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver     User          @relation(fields: [approverId], references: [id])
  templateStep TemplateStep? @relation(fields: [templateStepId], references: [id], onDelete: SetNull)
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  type      String
  requestId Int
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  requestId Int
  actorId   Int
  action    String
  oldStatus String?
  newStatus String?
  comment   String?
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id])
}
